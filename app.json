{
  "expo": {
    "name": "YAHT - Yet Another Habit Tracker",
    "slug": "yaht",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.niqp.yaht"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "build": {
        "babel": {
          "include": [
            "@gorhom/bottom-sheet",
            "react-native-reanimated"
          ]
        }
      }
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "yaht-app",
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e5e2df4c-6b5a-40a0-8946-53d11fb886e2"
      }
    },
    "owner": "niqp"
  }
}
