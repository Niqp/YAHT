{
  "expo": {
    "name": "YAHT Habit Tracker",
    "slug": "yaht",
    "version": "1.0.1",
    "description": "A local-first habit tracker for daily, repetition, and timed habits with reminders, statistics, and data import/export.",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.niqp.yaht",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.niqp.yaht",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/icon-mono.png",
        "backgroundImage": "./assets/images/background-image.png",
        "backgroundColor": "#f68a33"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "build": {
        "babel": {
          "include": [
            "@gorhom/bottom-sheet",
            "react-native-reanimated"
          ]
        }
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#023c69",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF7F1",
          "image": "./assets/images/adaptive-icon.png",
          "imageWidth": 260,
          "dark": {
            "backgroundColor": "#16110D",
            "image": "./assets/images/adaptive-icon.png"
          }
        }
      ],
      "expo-router",
      "./plugins/with-native-reminder-actions",
      "react-native-permissions",
      "expo-localization"
    ],
    "scheme": "yaht-app",
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e5e2df4c-6b5a-40a0-8946-53d11fb886e2"
      }
    },
    "owner": "niqp"
  }
}
